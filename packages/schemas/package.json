{
  "name": "@repo/schemas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The shared domain contract: zod schemas + inferred types for api, web, and future clients.",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./common": {
      "import": {
        "types": "./dist/common.d.ts",
        "default": "./dist/common.js"
      },
      "require": {
        "types": "./dist/common.d.cts",
        "default": "./dist/common.cjs"
      }
    },
    "./auth": {
      "import": {
        "types": "./dist/auth.d.ts",
        "default": "./dist/auth.js"
      },
      "require": {
        "types": "./dist/auth.d.cts",
        "default": "./dist/auth.cjs"
      }
    },
    "./user": {
      "import": {
        "types": "./dist/user.d.ts",
        "default": "./dist/user.js"
      },
      "require": {
        "types": "./dist/user.d.cts",
        "default": "./dist/user.cjs"
      }
    },
    "./tasks": {
      "import": {
        "types": "./dist/tasks.d.ts",
        "default": "./dist/tasks.js"
      },
      "require": {
        "types": "./dist/tasks.d.cts",
        "default": "./dist/tasks.cjs"
      }
    },
    "./ai": {
      "import": {
        "types": "./dist/ai.d.ts",
        "default": "./dist/ai.js"
      },
      "require": {
        "types": "./dist/ai.d.cts",
        "default": "./dist/ai.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
