  "info": {
    "title": "Agentic Dev Kit API",
    "description": "Auth, tasks, and AI (copilot/speech) endpoints.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "SettingsResponseDto_Output": {
        "type": "object",
        "properties": {
          "ai": {
            "type": "object",
            "properties": {
              "providerMode": {
                "type": "string",
                "enum": [
                  "mock",
                  "auto"
                ]
              },
              "awsRegion": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50
              },
              "dailyTokenBudget": {
                "type": "integer",
                "exclusiveMinimum": true,
                "maximum": 9007199254740991,
                "minimum": 0
              },
              "copilot": {
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string",
                    "pattern": "^(google|bedrock|mock):.+$"
                  },
                  "temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 2
                  },
                  "maxOutputTokens": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 32768
                  },
                  "topP": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "nullable": true
                  }
                },
                "required": [
                  "model",
                  "temperature",
                  "maxOutputTokens",
                  "topP"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "providerMode",
              "awsRegion",
              "dailyTokenBudget",
              "copilot"
            ],
            "additionalProperties": false
          },
          "general": {
            "type": "object",
            "properties": {
              "corsOrigins": {
                "minItems": 1,
                "maxItems": 20,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^https?:\\/\\/[^\\s/]+$"
                }
              },
              "requireEmailVerification": {
                "type": "boolean"
              }
            },
            "required": [
              "corsOrigins",
              "requireEmailVerification"
            ],
            "additionalProperties": false
          },
          "secrets": {
            "type": "object",
            "properties": {
              "googleApiKey": {
                "type": "object",
                "properties": {
                  "set": {
                    "type": "boolean"
                  },
                  "hint": {
                    "type": "string",
                    "nullable": true
                  }
                },
                "required": [
                  "set",
                  "hint"
                ],
                "additionalProperties": false
              },
              "bedrockApiKey": {
                "type": "object",
                "properties": {
                  "set": {
                    "type": "boolean"
                  },
                  "hint": {
                    "type": "string",
                    "nullable": true
                  }
                },
                "required": [
                  "set",
                  "hint"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "googleApiKey",
              "bedrockApiKey"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "ai",
          "general",
          "secrets"
        ],
        "additionalProperties": false
      },
      "SettingsUpdateDto": {
        "type": "object",
        "properties": {
          "ai": {
            "type": "object",
            "properties": {
              "providerMode": {
                "type": "string",
                "enum": [
                  "mock",
                  "auto"
                ]
              },
              "awsRegion": {
                "type": "string",
                "minLength": 1,
                "maxLength": 50
              },
              "dailyTokenBudget": {
                "type": "integer",
                "exclusiveMinimum": true,
                "maximum": 9007199254740991,
                "minimum": 0
              },
              "copilot": {
                "type": "object",
                "properties": {
                  "model": {
                    "type": "string",
                    "pattern": "^(google|bedrock|mock):.+$"
                  },
                  "temperature": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 2
                  },
                  "maxOutputTokens": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 32768
                  },
                  "topP": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "nullable": true
                  }
                }
              }
            }
          },
          "general": {
            "type": "object",
            "properties": {
              "corsOrigins": {
                "minItems": 1,
                "maxItems": 20,
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^https?:\\/\\/[^\\s/]+$"
                }
              },
              "requireEmailVerification": {
                "type": "boolean"
              }
            }
          },
          "secrets": {
            "type": "object",
            "properties": {
              "googleApiKey": {
                "type": "string",
                "minLength": 8,
                "maxLength": 512,
                "nullable": true
              },
              "bedrockApiKey": {
                "type": "string",
                "minLength": 8,
                "maxLength": 512,
                "nullable": true
              }
            }
          }
        }
      },
      "SignupDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 254,
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "maxLength": 128
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          }
        },
        "required": [
          "email",
          "password",
          "name"
        ]
      },
      "AuthResponseDto_Output": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[0-9a-f]{24}$"
              },
              "email": {
                "type": "string",
                "format": "email",
                "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "emailVerified": {
                "type": "boolean"
              },
              "role": {
                "type": "string",
                "enum": [
                  "admin",
                  "member"
                ]
              },
              "createdAt": {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              }
            },
            "required": [
              "id",
              "email",
              "name",
              "emailVerified",
              "role",
              "createdAt"
            ],
            "additionalProperties": false
          },
          "refreshToken": {
            "type": "string"
          }
        },
        "required": [
          "accessToken",
          "user"
        ],
        "additionalProperties": false
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "maxLength": 254,
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "password": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshRequestDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "minLength": 1
          }
        },
        "default": {}
      },
      "UserDto_Output": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9a-f]{24}$"
          },
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
          },
          "emailVerified": {
            "type": "boolean"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "member"
            ]
          },
          "createdAt": {
