# Copy to .env for local development. Every variable is validated at boot
# (src/config/env.schema.ts) — the app refuses to start on bad config.

NODE_ENV=development
PORT=3000

# Single-node replica set from docker-compose (`pnpm db:up`).
# directConnection=true is required with the localhost replica set.
MONGODB_URI=mongodb://localhost:27017/agentic-dev-kit?replicaSet=rs0&directConnection=true

# openssl rand -base64 48
JWT_ACCESS_SECRET=dev-only-secret-change-me-please-0123456789abcdef
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_GRACE_WINDOW_SECONDS=45

# Comma-separated browser origins allowed to call the API with credentials.
CORS_ORIGINS=http://localhost:5173
# Set true in production (refresh cookie is then Secure).
COOKIE_SECURE=false

# console = log emails instead of sending (dev default).
MAILER_DRIVER=console
REQUIRE_EMAIL_VERIFICATION=false

# ---------------------------------------------------------------------------
# AI — the kit runs fully keyless out of the box (mock echo provider).
# Provide a key and switch AI_PROVIDER_MODE to use real models.
#   mock : never call real providers (default — works with zero keys)
#   auto : use real providers per feature-models.ts, requires keys below
AI_PROVIDER_MODE=mock
# Google Gemini (chat + speech): https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Amazon Bedrock API key (chat): https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys.html
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
# Per-feature model overrides (see src/ai/feature-models.ts), e.g.:
# AI_MODEL_COPILOT_CHAT=google:gemini-3.1-pro-preview
# Daily per-user LLM token budget (input+output, all features).
AI_DAILY_TOKEN_BUDGET=200000
